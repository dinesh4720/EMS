{
  "name": "owlin-analytics",
  "private": true,
  "version": "2.0.0",
  "description": "Owlin Analytics — Mixpanel-like product analytics platform",
  "author": "Dinesh <dinesh@example.com>",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"npm run electron:dev\"",
    "electron:dev": "tsc -p electron/tsconfig.json && VITE_DEV_SERVER_URL=http://localhost:4000 electron dist-electron/main.js",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json && electron-builder --mac",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.2",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "socket.io-client": "^4.8.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^8.0.16"
  },
  "overrides": {
    "socket.io-parser": ">=4.2.6",
    "flatted": ">=3.4.2",
    "shell-quote": "1.8.4"
  }
}
