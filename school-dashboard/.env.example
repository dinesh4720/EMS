# Development Environment Variables
# Copy this file to .env and adjust values for your local setup.
# DO NOT add API keys here — all AI calls go through the backend proxy.

# Local Backend API
VITE_API_URL=http://localhost:3002/api
VITE_SOCKET_URL=http://localhost:3002

# App version — used by Sentry for release tracking
VITE_APP_VERSION=0.0.0-dev

# Optional override for the default academic year. When unset, the dashboard
# derives the current year from the browser clock (April-March cycle).
# Format: YYYY-YY (e.g., 2025-26).
# VITE_CURRENT_ACADEMIC_YEAR=2025-26
