# Production Environment Variables
# REQUIRED: Set VITE_API_URL to your real backend URL before building.
# Override these in your CI/CD environment variables — do NOT commit real values.
#
# TLS is enforced in production: VITE_API_URL must start with https:// (and an
# explicit VITE_SOCKET_URL must be https:// or wss://). A plaintext http:// URL
# fails the build/mount with a config-error page because auth cookies ride
# credentials:'include' and would be exposed as mixed content. Use http://localhost
# only in development.

VITE_API_URL=https://your-backend-url.example.com/api

# Socket server URL — only required when the socket server runs on a DIFFERENT domain.
# VITE_SOCKET_URL=https://your-socket-server.example.com

# App version — set this to the release tag (e.g. 1.2.3) in CI/CD
VITE_APP_VERSION=1.0.0

# Owlin Analytics — OPTIONAL client-side product tracking.
# WARNING: every VITE_-prefixed value is compiled into the public JS bundle and is
# world-readable. VITE_OWLIN_API_KEY (if set) MUST be a write-only event-ingestion
# key — never a read/admin key. If your Owlin instance only issues privileged keys,
# proxy tracking through the backend instead of setting this here.
# VITE_OWLIN_ENDPOINT=https://your-owlin-server.example.com/api/v1/events/batch
# VITE_OWLIN_API_KEY=your-write-only-ingestion-key
