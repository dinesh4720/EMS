# Production Environment Variables
# REQUIRED: Set VITE_API_URL to your real backend URL before building.
# Override these in your CI/CD environment variables — do NOT commit real values.

VITE_API_URL=https://your-backend-url.example.com/api

# Socket server URL — only required when the socket server runs on a DIFFERENT domain.
# VITE_SOCKET_URL=https://your-socket-server.example.com

# App version — set this to the release tag (e.g. 1.2.3) in CI/CD
VITE_APP_VERSION=1.0.0

# Owlin Analytics (client-side tracking key — safe to commit if non-sensitive)
# VITE_OWLIN_ENDPOINT=https://your-owlin-server.example.com/api/v1/events/batch
