# Production Environment Variables
# Update this with your actual Render backend URL after deployment

VITE_API_URL=https://your-backend-app.onrender.com/api

# App version — set this to the release tag (e.g. 1.2.3) in CI/CD
VITE_APP_VERSION=1.0.0

# Owlin Analytics (client-side tracking key - safe to commit)
VITE_OWLIN_ENDPOINT=https://owlin-server.onrender.com/api/v1/events/batch
