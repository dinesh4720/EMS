# Test Environment Configuration
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001

# Error Tracking (Sentry)
# Create a project at https://sentry.io and set the DSN here or in CI secrets.
# VITE_SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000

# Test User Credentials
# Copy this file to .env.test and fill in real values
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=your-test-password

TEST_TEACHER_EMAIL=teacher@example.com
TEST_TEACHER_PASSWORD=your-test-password

TEST_ACCOUNTANT_EMAIL=accountant@example.com
TEST_ACCOUNTANT_PASSWORD=your-test-password

TEST_RECEPTIONIST_EMAIL=receptionist@example.com
TEST_RECEPTIONIST_PASSWORD=your-test-password
