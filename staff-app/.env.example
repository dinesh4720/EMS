APP_ENV=development
EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Use the generic keys to target one environment directly.
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com
# EXPO_PUBLIC_SOCKET_URL=https://api.example.com

# Or provide one value per environment and switch with APP_ENV.
EXPO_PUBLIC_API_BASE_URL_DEVELOPMENT=http://localhost:3001
EXPO_PUBLIC_SOCKET_URL_DEVELOPMENT=http://localhost:3001

EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.example.com
EXPO_PUBLIC_SOCKET_URL_STAGING=https://staging-api.example.com

EXPO_PUBLIC_API_BASE_URL_PRODUCTION=https://api.example.com
EXPO_PUBLIC_SOCKET_URL_PRODUCTION=https://api.example.com
